# Deploy Agent Configuration

# Required: Secret key for internal operations (minimum 32 characters)
DEVVER_SECRET=your-secret-key-minimum-32-chars-long

# Required: Widget URL for overlay functionality (must be HTTPS)
DEVVER_WIDGET_URL=https://your-widget-url.com/widget.js

# Optional: Base directory for data storage (default: /app)
DEVVER_DATA_DIR=/app

# Optional: Server port (default: 8080)
PORT=8080
